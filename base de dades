-- 0. CONFIGURACIÓN INICIAL
CREATE DATABASE IF NOT EXISTS revenda_segura;
USE revenda_segura;

-- Ajuste de permisos para el usuario del backend
CREATE USER IF NOT EXISTS 'app_revenda'@'%' IDENTIFIED BY 'TuPassword Segura123!';
GRANT ALL PRIVILEGES ON revenda_segura.* TO 'app_revenda'@'%';
FLUSH PRIVILEGES;

-- 1. USUARIOS: Identidad digital y reputación
CREATE TABLE usuarios (
    id_usuario INT AUTO_INCREMENT PRIMARY KEY,
    nombre_completo VARCHAR(255) NOT NULL,
    email VARCHAR(150) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    dni_nie VARCHAR(20) UNIQUE,
    path_dni_frontal VARCHAR(255),
    path_dni_reverso VARCHAR(255),
    path_video_verificacion VARCHAR(255),
    estado_verificacion ENUM('pendiente', 'verificado', 'rechazado') DEFAULT 'pendiente',
    stripe_account_id VARCHAR(100),
    reputacion_media DECIMAL(3,2) DEFAULT 5.00,
    total_resenas INT DEFAULT 0,
    fecha_registro TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 2. EVENTOS: Espectáculos (Añadido campo para imagen/poster)
CREATE TABLE eventos (
    id_evento INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(200) NOT NULL,
    fecha_evento DATETIME NOT NULL,
    ubicacion VARCHAR(255) NOT NULL,
    categoria ENUM('concierto', 'festival', 'deporte'),
    path_imagen_poster VARCHAR(255) -- Ruta al archivo en tu bucket S3
);

-- 3. ENTRADAS: Control de precios y detalles de ubicación
CREATE TABLE entradas (
    id_entrada INT AUTO_INCREMENT PRIMARY KEY,
    id_evento INT,
    id_vendedor INT,
    precio_reventa DECIMAL(10,2) NOT NULL,
    cod_digital_unico VARCHAR(100) UNIQUE,
    estado ENUM('disponible', 'vendida', 'validada') DEFAULT 'disponible',
    es_destacada BOOLEAN DEFAULT FALSE,
    tipo_asiento VARCHAR(100) NOT NULL,
    fila VARCHAR(50),
    asiento VARCHAR(50),
    FOREIGN KEY (id_evento) REFERENCES eventos(id_evento),
    FOREIGN KEY (id_vendedor) REFERENCES usuarios(id_usuario)
);

-- 4. TRANSACCIONES: Pagos registrados desde Stripe
CREATE TABLE transacciones (
    id_transaccion INT AUTO_INCREMENT PRIMARY KEY,
    id_entrada INT,
    id_comprador INT,
    stripe_payment_intent_id VARCHAR(255),
    monto_base DECIMAL(10,2),
    comision_plataforma DECIMAL(10,2),
    monto_total DECIMAL(10,2),
    estado_pago ENUM('pendiente', 'completado', 'fallido', 'reembolsado'),
    fecha_transaccion TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_entrada) REFERENCES entradas(id_entrada),
    FOREIGN KEY (id_comprador) REFERENCES usuarios(id_usuario)
);

-- 5. ESCROW: Gestión de fondos retenidos
CREATE TABLE liquidaciones_escrow (
    id_escrow INT AUTO_INCREMENT PRIMARY KEY,
    id_transaccion INT, -- Corregido el error de nombre del PDF
    fecha_liberacion_prevista DATETIME, -- Fecha evento + 48h
    estado_fondos ENUM('retenido', 'liquidado', 'bloqueado_fraude') DEFAULT 'retenido',
    stripe_transfer_id VARCHAR(255), -- Para registrar el envío final de dinero al vendedor
    FOREIGN KEY (id_transaccion) REFERENCES transacciones(id_transaccion)
);

-- 6. RECLAMACIONES: Gestión de disputas
CREATE TABLE reclamaciones (
    id_reclamacion INT AUTO_INCREMENT PRIMARY KEY,
    id_transaccion INT,
    descripcion_fraude TEXT,
    estado_reclamacion ENUM('abierta', 'resuelta_comprador', 'resuelta_vendedor') DEFAULT 'abierta',
    fecha_reclamacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_transaccion) REFERENCES transacciones(id_transaccion)
);

-- 7. RESEÑAS: Sistema de reputación
CREATE TABLE resenas (
    id_resena INT AUTO_INCREMENT PRIMARY KEY,
    id_transaccion INT,
    id_calificador INT,
    id_calificado INT,
    puntuacion INT CHECK (puntuacion BETWEEN 1 AND 5),
    comentario TEXT,
    FOREIGN KEY (id_transaccion) REFERENCES transacciones(id_transaccion),
    FOREIGN KEY (id_calificador) REFERENCES usuarios(id_usuario),
    FOREIGN KEY (id_calificado) REFERENCES usuarios(id_usuario)
);

-- AUTOMATIZACIÓN DE SEGURIDAD (TRIGGER)
-- Si un comprador abre una reclamación, el dinero se congela automáticamente en el Escrow
DELIMITER //
CREATE TRIGGER tg_bloquear_fondos_por_fraude
AFTER INSERT ON reclamaciones
FOR EACH ROW
BEGIN
    UPDATE liquidaciones_escrow 
    SET estado_fondos = 'bloqueado_fraude'
    WHERE id_transaccion = NEW.id_transaccion;
END;
//
DELIMITER ;


